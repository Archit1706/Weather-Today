<%- include("partials/header") -%>
    <div class="container">
        <form action="/" method="post">
            <input type="text" name="city" placeholder="Search for a city" id="city-search" class="search-box" autocomplete="off" autocapitalize="on" required>
            <button type="submit">Search</button>
        </form>

        <% if (error && error.length) { %>
            <div class="error-banner"><%= error %></div>
        <% } %>

        <% if (location && location.length) { %>
            <div class="weather-info">
                <div class="location">
                    <div class="city"><%= location %></div>
                    <div class="date"><%= date %></div>
                </div>

                <div class="current">
                    <% if (icon && icon.length) { %>
                        <img class="icon" src="https://openweathermap.org/img/wn/<%= icon %>@4x.png" alt="<%= description %>">
                    <% } %>
                    <div class="temp"><%= temp %><span>°C</span></div>
                    <div class="description"><%= description %></div>
                    <div class="hi-low"><%= tempMinMax %></div>
                </div>
            </div>
        <% } %>
    </div>

<%- include("partials/footer") -%>
